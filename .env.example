# Database Configuration
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=your_password
DB_NAME=whot_game
DB_PORT=3306

# Server Configuration
NODE_ENV=development
PORT=5000
HOST=localhost

# JWT Configuration
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRATION=7d
JWT_REFRESH_SECRET=your_refresh_secret_key
JWT_REFRESH_EXPIRATION=30d

# Socket.IO Configuration
SOCKET_PORT=5001
SOCKET_CORS_ORIGIN=http://localhost:3000,http://localhost:8080

# CORS Configuration
CORS_ORIGIN=http://localhost:3000,http://localhost:8080

# Redis Configuration (Optional for scaling)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Payment/Wallet Configuration
WALLET_MIN_DEPOSIT=100
WALLET_MAX_DEPOSIT=1000000
PLATFORM_FEE_PERCENTAGE=20
TOURNAMENT_FEE_PERCENTAGE=30

# Email Configuration
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password
SMTP_FROM=noreply@9jawin.com

# File Upload
MAX_UPLOAD_SIZE=5242880
UPLOAD_DIR=./uploads

# Admin Configuration
ADMIN_EMAIL=admin@9jawin.com
ADMIN_PASSWORD=change_this_admin_password

# WordPress Integration
WORDPRESS_API_KEY=your_wordpress_api_key
WORDPRESS_SITE_URL=https://yoursite.com
WORDPRESS_REST_API_URL=https://yoursite.com/wp-json

# Logging
LOG_LEVEL=debug
LOG_FILE=./logs/app.log